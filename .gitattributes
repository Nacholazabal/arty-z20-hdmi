# ── Git LFS — binary hardware artifacts ──────────────────────────────────────
# Bitstreams
*.bit       filter=lfs diff=lfs merge=lfs -text

# Hardware definition files (Vivado export — ZIP under the hood)
*.hdf       filter=lfs diff=lfs merge=lfs -text

# Compiled ELF application binaries
*.elf       filter=lfs diff=lfs merge=lfs -text

# Vivado checkpoint files (large, binary — track if you ever commit them)
*.dcp       filter=lfs diff=lfs merge=lfs -text

# ── Text files — explicit line-ending normalisation ───────────────────────────
*.v         text eol=lf
*.vhd       text eol=lf
*.vhdl      text eol=lf
*.xdc       text eol=lf
*.bd        text eol=lf
*.tcl       text eol=lf
*.ps1       text eol=crlf
*.c         text eol=lf
*.h         text eol=lf
*.md        text eol=lf
*.gitignore text eol=lf
